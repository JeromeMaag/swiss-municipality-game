# Local development template.
# Copy this file to .env, replace SECRET_KEY, and never commit .env.
DEBUG=False
SECRET_KEY=replace-this-with-a-local-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Matches the local PostGIS service from docker-compose.yml.
DATABASE_URL=postgis://gemeindeguess:gemeindeguess@localhost:5432/gemeindeguess
DJANGO_SETTINGS_MODULE=config.settings
